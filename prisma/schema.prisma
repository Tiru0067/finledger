generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  viewer
  analyst
  admin
}

enum Status {
  active
  inactive
}

enum RecordType {
  income
  expense
}

enum Category {
  revenue
  salary
  operations
  marketing
  utilities
  rent
  travel
  equipment
  taxes
  other
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(viewer)
  status        Status   @default(active)
  isSuperAdmin  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  records       Record[]

  @@map("users")
}

model Record {
  id          Int     @id @default(autoincrement())
  amount      Decimal    @db.Decimal(15, 2)
  type        RecordType
  category    Category
  date        DateTime
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy   Int
  user        User       @relation(fields: [createdBy], references: [id])

  @@map("records")
}